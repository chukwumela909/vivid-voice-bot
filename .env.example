# ── WorldStreet Vivid voice bot ──────────────────────────────────────────────
# Copy to bot/.env and fill in. These keys live ONLY on the bot; the browser
# never receives them.

# Speech-to-text (Deepgram)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_ENDPOINTING=250

# LLM — switchable. LLM_PROVIDER=groq (default) or openai.
LLM_PROVIDER=groq
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=320
# Groq (default provider)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
# OpenAI (only if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Text-to-speech — switchable. TTS_PROVIDER=elevenlabs (default) or cartesia.
TTS_PROVIDER=elevenlabs

# ElevenLabs (default TTS). The browser's voice menu picks the voice per session
# (?voice=); ELEVENLABS_VOICE_ID is the fallback when none is selected.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_STYLE=0.45
ELEVENLABS_STABILITY=0.35
ELEVENLABS_SPEAKER_BOOST=true

# Cartesia (only if TTS_PROVIDER=cartesia)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# Turn-taking (Silero VAD)
VAD_STOP_SECS=0.5
VAD_START_SECS=0.2

# Tool bridge — how long the bot waits for the browser to run a tool.
TOOL_TIMEOUT_SECS=20

# Context auto-summarization (token-budget control)
SUMMARIZE_AT_TOKENS=4000
SUMMARIZE_AT_MESSAGES=24
SUMMARY_TARGET_TOKENS=1500
SUMMARY_KEEP_MESSAGES=6

# Transport: "smallwebrtc" (default, P2P, local dev) or "daily" (managed, cloud).
TRANSPORT=smallwebrtc
DAILY_API_KEY=
# JSON array of STUN/TURN servers (must match the web app's NEXT_PUBLIC_WEBRTC_ICE_SERVERS).
WEBRTC_ICE_SERVERS=["stun:stun.l.google.com:19302"]

# CORS — comma-separated web origins allowed to reach the bot, or "*" for dev.
ALLOWED_ORIGINS=*

# Signaling port
BOT_PORT=7860
